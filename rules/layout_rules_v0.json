{
  "layout_rules_version": "0.1.0",
  "sheet": {
    "format": "A3_landscape",
    "width_mm": 420,
    "height_mm": 297
  },
  "grid": {
    "unit_mm": 5,
    "visible_in_final": false,
    "debug_overlay_supported": true
  },
  "component_size_policies": {
    "SVR": {
      "policy": "fixed_sheet_box",
      "width_mm": 15,
      "height_mm": 40,
      "applies_to_all_models": true
    },
    "SVS": {
      "policy": "fixed_sheet_box",
      "width_mm": 30,
      "height_mm": 20,
      "applies_to_models": ["SVS-I/LT5-I", "SVS-I/LT6-I"]
    }
  },
  "component_requirements": {
    "DH": {
      "frame_required": true,
      "applies_to_all_models": true,
      "placement": "frame_bottom_on_floor_line",
      "geometry_scope": "complete_model_space_assembly",
      "frame_symbol": {
        "left_leg_x_ratio": 0.08,
        "right_leg_x_ratio": 0.92,
        "top_y_ratio": 0.76,
        "foot_width_mm": 6,
        "line_width_mm": 0.75
      }
    }
  },
  "mounting_rules": [
    {
      "child_family": "SVR",
      "host_family": "DH",
      "contact": "child_bottom_to_host_mounting_plane",
      "host_mounting_plane_offset_from_box_top_mm": 10,
      "horizontal_alignment": "center",
      "gap_mm": 0,
      "required": true
    },
    {
      "child_family": "SVR",
      "host_family": "EXT",
      "contact": "child_bottom_to_host_mounting_plane",
      "host_mounting_plane_offset_from_box_top_mm": 0,
      "horizontal_alignment": "center",
      "gap_mm": 0,
      "required": true
    }
  ],
  "orientation_rules": [
    {
      "family": "SVR",
      "policy": "mirror_about_vertical_axis_to_face_incoming_pipe",
      "transform_component_and_anchors_together": true
    }
  ],
  "conveying_route_style": {
    "applies_to": [
      "vacuum_air",
      "dried_material",
      "undried_material",
      "gravity_dried_material",
      "discharge"
    ],
    "stroke_width_mm": 1.5,
    "previous_stroke_width_mm": 2.25,
    "reduction_percent_from_previous": 33.33,
    "original_stroke_width_mm": 2.5,
    "reduction_percent_from_original": 40,
    "excludes": ["drying_air"]
  },
  "shared_vacuum_header": {
    "assembly_type": "Micro Scan",
    "shared_blower": true,
    "station_family": "SVS",
    "station_connection_face": "top",
    "station_approach": "vertical_from_above",
    "branch_connection": "tee",
    "branch_per_SVR": true,
    "header_extension_policy": "extend_to_furthest_receiver"
  },
  "process_air_circuit": {
    "id": "DFD_DH_STANDARD",
    "medium": "drying_air",
    "applies_to_all_DFD_DH_models": true,
    "routes": {
      "supply": {"direction": "DFD_to_DH"},
      "return": {"direction": "DH_to_DFD"}
    },
    "dfd_connection_face": "top",
    "dh_connection_face": "side_toward_dfd",
    "horizontal_segment_policy": "stretch_to_machine_spacing",
    "bend_radius_mm": 5,
    "line_colour": "#222222",
    "rendering": "outlined_duct",
    "outer_line_width_mm": 2.2,
    "inner_line_width_mm": 1.4,
    "flow_arrows_required": true
  }
}
